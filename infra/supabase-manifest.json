{
  "$schema": "./supabase-manifest.schema.md",
  "version": 1,
  "siteUrl": "https://app.accountancyos.com",
  "redirectAllowList": [
    "https://app.accountancyos.com/*",
    "https://app.accountancyos.com/portal/reset-password",
    "https://accountancyos.lovable.app/*",
    "https://accountancyos.lovable.app/portal/reset-password"
  ],
  "authEmailHook": {
    "function": "auth-email-hook",
    "senderDomain": "notify.accountancyos.com",
    "fromAddress": "noreply@accountancyos.com",
    "actionTypes": ["signup", "magiclink", "recovery", "invite", "email_change", "reauthentication"]
  },
  "edgeFunctions": [
    { "name": "auth-email-hook", "verifyJwt": false, "critical": true },
    { "name": "process-email-queue", "verifyJwt": false, "critical": true },
    { "name": "handle-email-unsubscribe", "verifyJwt": false, "critical": false },
    { "name": "accept-portal-invite-signup", "verifyJwt": false, "critical": true },
    { "name": "seed-portal-test-users", "verifyJwt": false, "critical": false },
    { "name": "portal-qa-probe", "verifyJwt": false, "critical": false },
    { "name": "stripe-checkout", "verifyJwt": true, "critical": true },
    { "name": "stripe-webhook", "verifyJwt": false, "critical": true },
    { "name": "customer-portal", "verifyJwt": true, "critical": true },
    { "name": "check-subscription", "verifyJwt": true, "critical": false },
    { "name": "onboarding-stripe-checkout", "verifyJwt": false, "critical": true },
    { "name": "onboarding-stripe-verify", "verifyJwt": false, "critical": true },
    { "name": "stripe-connect-onboard", "verifyJwt": true, "critical": false },
    { "name": "stripe-connect-charge", "verifyJwt": true, "critical": false },
    { "name": "ch-submit", "verifyJwt": true, "critical": true },
    { "name": "companies-house-sync", "verifyJwt": true, "critical": false },
    { "name": "hmrc-auth", "verifyJwt": true, "critical": true },
    { "name": "hmrc-callback", "verifyJwt": false, "critical": true },
    { "name": "hmrc-ct-submit", "verifyJwt": true, "critical": true },
    { "name": "hmrc-ct-poll", "verifyJwt": false, "critical": true },
    { "name": "hmrc-ct-delete", "verifyJwt": false, "critical": false },
    { "name": "hmrc-vat-obligations", "verifyJwt": true, "critical": true },
    { "name": "hmrc-vat-submit", "verifyJwt": true, "critical": true },
    { "name": "cis-submit", "verifyJwt": true, "critical": true },
    { "name": "rti-submit", "verifyJwt": true, "critical": true },
    { "name": "send-engagement-letter", "verifyJwt": true, "critical": true },
    { "name": "generate-filing-pdf", "verifyJwt": true, "critical": true },
    { "name": "gmail-auth", "verifyJwt": true, "critical": false },
    { "name": "gmail-callback", "verifyJwt": false, "critical": false },
    { "name": "gmail-send", "verifyJwt": true, "critical": false },
    { "name": "gmail-sync", "verifyJwt": false, "critical": false },
    { "name": "outlook-auth", "verifyJwt": true, "critical": false },
    { "name": "outlook-callback", "verifyJwt": false, "critical": false },
    { "name": "outlook-send", "verifyJwt": true, "critical": false },
    { "name": "outlook-sync", "verifyJwt": false, "critical": false },
    { "name": "truelayer-auth", "verifyJwt": true, "critical": false },
    { "name": "truelayer-callback", "verifyJwt": false, "critical": false },
    { "name": "truelayer-sync", "verifyJwt": true, "critical": false },
    { "name": "truelayer-sync-scheduled", "verifyJwt": false, "critical": false },
    { "name": "fx-rates", "verifyJwt": true, "critical": false },
    { "name": "chaser-tick", "verifyJwt": false, "critical": true },
    { "name": "chaser-trigger-scan", "verifyJwt": false, "critical": false },
    { "name": "sla-check", "verifyJwt": false, "critical": true },
    { "name": "session-cleanup", "verifyJwt": false, "critical": false },
    { "name": "workflow-tick", "verifyJwt": false, "critical": true },
    { "name": "process-automation-events", "verifyJwt": false, "critical": true },
    { "name": "dormant-lead-scan", "verifyJwt": false, "critical": false },
    { "name": "invoice-overdue-scan", "verifyJwt": false, "critical": false },
    { "name": "automation-dry-run", "verifyJwt": true, "critical": false },
    { "name": "clone-workpaper-template", "verifyJwt": true, "critical": false },
    { "name": "handle-email-unsubscribe", "verifyJwt": false, "critical": false },
    { "name": "gdpr-data-export", "verifyJwt": true, "critical": false },
    { "name": "gdpr-data-deletion", "verifyJwt": true, "critical": false }
  ],
  "cronJobs": [
    { "name": "process-email-queue", "expectedSchedule": "*/5 seconds OR every 5s" },
    { "name": "chaser-tick", "expectedSchedule": "*/15 minutes" },
    { "name": "sla-check", "expectedSchedule": "hourly" },
    { "name": "workflow-tick", "expectedSchedule": "*/5 minutes" },
    { "name": "session-cleanup", "expectedSchedule": "hourly" },
    { "name": "dormant-lead-scan", "expectedSchedule": "daily" },
    { "name": "invoice-overdue-scan", "expectedSchedule": "daily" },
    { "name": "truelayer-sync-scheduled", "expectedSchedule": "*/6 hours" }
  ],
  "requiredSecrets": [
    "LOVABLE_API_KEY",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_ANON_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "HMRC_CLIENT_ID",
    "HMRC_CLIENT_SECRET",
    "COMPANIES_HOUSE_API_KEY",
    "TRUELAYER_CLIENT_ID",
    "TRUELAYER_CLIENT_SECRET",
    "GMAIL_CLIENT_ID",
    "GMAIL_CLIENT_SECRET",
    "OUTLOOK_CLIENT_ID",
    "OUTLOOK_CLIENT_SECRET",
    "PORTAL_SEED_SECRET"
  ],
  "emailInfrastructure": {
    "tables": ["email_send_log", "email_send_state", "suppressed_emails", "email_unsubscribe_tokens"],
    "publicRpcs": ["enqueue_email", "read_email_batch", "delete_email", "move_to_dlq"],
    "pgmqQueues": ["auth_emails", "transactional_emails"],
    "provider": "Lovable Email API"
  },
  "storageBuckets": [
    { "name": "email-assets", "public": true },
    { "name": "documents", "public": false },
    { "name": "filings", "public": false },
    { "name": "kyc", "public": false }
  ],
  "rlsRequiredTables": [
    "organizations", "organization_users", "user_roles", "profiles",
    "clients", "companies", "contacts", "engagements", "engagement_letters",
    "leads", "quotes", "quote_lines", "quote_acceptance_tokens",
    "onboarding_applications", "onboarding_documents",
    "portal_access", "accountant_client_links",
    "jobs", "job_tasks", "job_documents", "job_artifacts", "job_timeline",
    "deadlines", "services_catalog",
    "questionnaire_instances", "questionnaire_responses", "questionnaire_public_links",
    "bank_connections", "bank_accounts", "bank_transactions",
    "ledger_entries", "journals", "journal_lines",
    "bookkeeping_accounts", "bookkeeping_queries",
    "filings", "filing_submissions", "filing_events",
    "workpaper_instances", "workpaper_templates",
    "vat_returns", "vat_periods", "cis_returns", "rti_submissions",
    "employees", "payslips", "pay_runs",
    "email_messages", "email_queue", "email_send_log", "suppressed_emails",
    "connected_mailboxes", "templates", "message_templates"
  ]
}