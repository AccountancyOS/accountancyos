{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://moxpdejnucjjcplleefn.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "accountancyos-mcp",
      "version": "0.1.0",
      "title": "AccountancyOS"
    },
    "tools": [
      {
        "name": "list_clients",
        "title": "List clients",
        "description": "List clients in the signed-in user's organisation. Returns id, name, email, status and type.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "maxLength": 200,
              "description": "Optional case-insensitive substring to match against first/last name or email."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Max rows to return (1-100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_jobs",
        "title": "List jobs",
        "description": "List active jobs in the signed-in user's organisation, most recently updated first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "maxLength": 64,
              "description": "Optional exact status filter (e.g. 'in_progress', 'completed')."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Max rows to return (1-100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_upcoming_deadlines",
        "title": "List upcoming deadlines",
        "description": "List upcoming (not-yet-filed) statutory and internal deadlines in the signed-in user's organisation, soonest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "within_days": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 60,
              "description": "Only include deadlines due within this many days from today."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50,
              "description": "Max rows to return (1-200)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
