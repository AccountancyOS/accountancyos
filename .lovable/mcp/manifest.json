{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://moxpdejnucjjcplleefn.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "accountancyos-mcp",
      "version": "0.1.0",
      "title": "AccountancyOS"
    },
    "tools": [
      {
        "name": "list_clients",
        "title": "List clients",
        "description": "List clients in the signed-in user's organisation. Returns id, name, email, status and type.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "maxLength": 200,
              "description": "Optional case-insensitive substring to match against first/last name or email."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Max rows to return (1-100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_jobs",
        "title": "List jobs",
        "description": "List active jobs in the signed-in user's organisation, most recently updated first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "maxLength": 64,
              "description": "Optional exact status filter (e.g. 'in_progress', 'completed')."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Max rows to return (1-100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_upcoming_deadlines",
        "title": "List upcoming deadlines",
        "description": "List upcoming (not-yet-filed) statutory and internal deadlines in the signed-in user's organisation, soonest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "within_days": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 60,
              "description": "Only include deadlines due within this many days from today."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50,
              "description": "Max rows to return (1-200)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "db_schema",
        "title": "Describe database schema",
        "description": "Return every public table with its columns (name, type, nullable, default). Use this first to discover what to query with db_select/db_insert/db_update/db_delete.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "db_select",
        "title": "Query any table",
        "description": "Read rows from any public table. RLS applies (acts as the signed-in user). Use db_schema first to discover columns.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "table": {
              "type": "string",
              "minLength": 1,
              "description": "Public table name."
            },
            "columns": {
              "type": "string",
              "default": "*",
              "description": "PostgREST select string, e.g. 'id, name' or '*'."
            },
            "filters": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "column": {
                    "type": "string"
                  },
                  "op": {
                    "type": "string",
                    "enum": [
                      "eq",
                      "neq",
                      "gt",
                      "gte",
                      "lt",
                      "lte",
                      "like",
                      "ilike",
                      "is",
                      "in",
                      "contains"
                    ]
                  },
                  "value": {}
                },
                "required": [
                  "column",
                  "op"
                ],
                "additionalProperties": false
              },
              "description": "Optional filters combined with AND. Value type depends on op; 'in' takes an array."
            },
            "order": {
              "type": "object",
              "properties": {
                "column": {
                  "type": "string"
                },
                "ascending": {
                  "type": "boolean",
                  "default": true
                }
              },
              "required": [
                "column"
              ],
              "additionalProperties": false
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "default": 50
            }
          },
          "required": [
            "table"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "db_insert",
        "title": "Insert rows",
        "description": "Insert one or more rows into a public table. RLS applies. Returns the inserted rows.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "table": {
              "type": "string",
              "minLength": 1
            },
            "rows": {
              "anyOf": [
                {
                  "type": "object",
                  "additionalProperties": {}
                },
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": {}
                  }
                }
              ]
            }
          },
          "required": [
            "table",
            "rows"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "db_update",
        "title": "Update rows",
        "description": "Update rows in a public table matching the filters. RLS applies. At least one filter is required.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "table": {
              "type": "string",
              "minLength": 1
            },
            "values": {
              "type": "object",
              "additionalProperties": {}
            },
            "filters": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "column": {
                    "type": "string"
                  },
                  "op": {
                    "type": "string",
                    "enum": [
                      "eq",
                      "neq",
                      "gt",
                      "gte",
                      "lt",
                      "lte",
                      "like",
                      "ilike",
                      "is",
                      "in"
                    ]
                  },
                  "value": {}
                },
                "required": [
                  "column",
                  "op"
                ],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "required": [
            "table",
            "values",
            "filters"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "db_delete",
        "title": "Delete rows",
        "description": "Delete rows from a public table matching the filters. RLS applies. At least one filter is required.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "table": {
              "type": "string",
              "minLength": 1
            },
            "filters": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "column": {
                    "type": "string"
                  },
                  "op": {
                    "type": "string",
                    "enum": [
                      "eq",
                      "neq",
                      "gt",
                      "gte",
                      "lt",
                      "lte",
                      "like",
                      "ilike",
                      "is",
                      "in"
                    ]
                  },
                  "value": {}
                },
                "required": [
                  "column",
                  "op"
                ],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "required": [
            "table",
            "filters"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "db_rpc",
        "title": "Call a database function",
        "description": "Invoke a Postgres function exposed via PostgREST (RPC). RLS and function grants apply.",
        "annotations": {
          "readOnlyHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "function_name": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "object",
              "additionalProperties": {}
            }
          },
          "required": [
            "function_name"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
